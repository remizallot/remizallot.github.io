# Ignore the contents of the _site directory and other cache directories
_site/
.sass-cache/

# Ignore the directory for local files during development
local/

# Ignore the Gemfile that is generated
Gemfile.lock

# Ignore files created by npm
node_modules
package-lock.json

# Ignore the vendor file at root level and bundle for alternative installation
/vendor/
.bundle/

# Ignore folders related to IDEs
.vscode/

# Ignore files created by MacOS
.DS_Store

# Local-only preview setup (older Ruby-compatible Jekyll pin, not used in production)
Gemfile.local
Gemfile.local.lock
_config_local.yml

# macOS reports this file's name in NFC form, but it's already tracked in NFD
# form (see files/pdf/CV Zallot Rémi...) -- APFS resolves both spellings
# to the same file, so ignore the NFC path to stop it being added as a
# separate (duplicate-content) tracked file.
files/pdf/CV Zallot Rémi Jun 2022 Website.pdf
